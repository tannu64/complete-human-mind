graph TD
    ENC["<b>MEMORY ENCODING</b><br/>Chapter 7.2"]

    ENC --> LOP["<b>Levels of Processing</b><br/>Craik & Lockhart 1972"]
    ENC --> MECH["<b>Encoding Mechanisms</b>"]
    ENC --> EMO["<b>Emotional Enhancement</b>"]

    LOP --> DEEP["Deep Semantic Processing<br/>Stronger memories<br/>Left inferior frontal gyrus"]
    LOP --> SHAL["Shallow Processing<br/>Surface features<br/>Weaker encoding"]
    LOP --> SME["Subsequent Memory Effect<br/>MTL activation predicts<br/>later remembering"]

    MECH --> TAG["<b>Synaptic Tagging & Capture</b><br/>Strong stim creates tag 1-2hrs<br/>Captures PRPs from other synapses<br/>Weak memories strengthened"]
    MECH --> SEP["<b>Pattern Separation - DG</b><br/>Similar inputs to distinct codes<br/>1M granule cells, 2-5% active<br/>Declines with aging"]
    MECH --> COMP["<b>Pattern Completion - CA3</b><br/>Partial cue to full recall<br/>30K recurrent synapses/neuron<br/>Autoassociative network"]

    EMO --> AH["Amygdala-Hippocampal<br/>Interaction"]
    EMO --> STRESS["Stress Hormones"]
    EMO --> FLASH["Flashbulb Memories"]

    AH --> AH1["BLA enhances hippocampal<br/>consolidation"]
    AH --> AH2["Modulates NE via LC<br/>and ACh via basal forebrain"]

    STRESS --> MOD["Moderate stress<br/>Enhanced consolidation"]
    STRESS --> SEV["Severe/chronic stress<br/>Impaired WM & retrieval<br/>Yerkes-Dodson curve"]

    FLASH --> FL1["Vivid & confident memories<br/>for emotional events"]
    FLASH --> FL2["Accuracy degrades over time<br/>Amygdala boosts confidence<br/>more than accuracy"]

